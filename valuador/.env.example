# =========================================================================
#  SERVICIO DE LECTURA DE PÁGINAS (necesario para que el scraping funcione)
# =========================================================================
# Zonaprop/Argenprop bloquean robots. Para esquivar ese bloqueo usamos un
# servicio que lee la página por nosotros desde una IP "real". Elegí UNO,
# creá una cuenta (tienen plan gratis) y pegá tu API key acá.
#
#   scraperapi   -> https://www.scraperapi.com   (recomendado, 1000 gratis/mes)
#   scrapingbee  -> https://www.scrapingbee.com
#   zenrows      -> https://www.zenrows.com
#
SCRAPER_PROVIDER=scraperapi
SCRAPER_API_KEY=

# --- Ajustes opcionales del scraping ---
# Cantidad de propiedades comparables para el benchmark (default 20).
BENCHMARK_SAMPLE_SIZE=20
# Timeout por lectura de página, en ms (default 60000).
SCRAPE_TIMEOUT_MS=60000

# =========================================================================
#  SUPABASE (OPCIONAL) — historial sincronizado entre dispositivos
# =========================================================================
# Si dejás esto vacío, el historial se guarda en el navegador (localStorage).
# Si lo completás, además se guarda en Supabase. (Settings -> API en Supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
