# --- Supabase (OPCIONAL) ---
# Si dejás estas variables vacías, la app guarda el historial en localStorage
# (en el navegador). Si las completás, el historial se guarda además en Supabase
# y sincroniza entre dispositivos.
#
# Las encontrás en: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Scraping (OPCIONAL) ---
# Cantidad de propiedades comparables a scrapear para el benchmark (default 20).
BENCHMARK_SAMPLE_SIZE=20
# Timeout por navegación de Playwright, en ms (default 30000).
SCRAPE_TIMEOUT_MS=30000
